# PostGuard Configuration
VITE_APP_VERSION="1.0.0"
VITE_APP_NAME="PostGuard"

# File upload settings
VITE_MAX_UPLOAD_SIZE=5000000000  # 5 GB
VITE_ROLLING_LIMIT=5000000000   # 5 GB per 2 weeks per email
VITE_UPLOAD_CHUNK_SIZE=10485760  # 10 MiB
VITE_FILEREAD_CHUNK_SIZE=10485760 # 10 MiB

# Backend URLs - Local development (use with docker-compose)
# Cryptify is used as our filehosting service
VITE_FILEHOST_URL="http://localhost:8000"
